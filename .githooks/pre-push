#!/bin/sh
set -eu

protected_branch="main"
protected_ref="refs/heads/$protected_branch"

while read -r local_ref local_sha remote_ref remote_sha; do
  if [ "$remote_ref" = "$protected_ref" ] && [ "${ALLOW_MAIN_PUSH:-}" != "1" ]; then
    echo "Direct pushes to '$protected_branch' are blocked in this repository." >&2
    echo "Push a feature branch and open a pull request instead." >&2
    echo "Set ALLOW_MAIN_PUSH=1 only for an explicit local override." >&2
    exit 1
  fi
done
