#!/bin/sh
set -eu

protected_branch="main"
current_branch="$(git symbolic-ref --quiet --short HEAD 2>/dev/null || true)"

if [ "$current_branch" = "$protected_branch" ] && [ "${ALLOW_MAIN_COMMIT:-}" != "1" ]; then
  echo "Commits on '$protected_branch' are blocked in this repository." >&2
  echo "Create a feature branch and open a pull request instead." >&2
  echo "Set ALLOW_MAIN_COMMIT=1 only for an explicit local override." >&2
  exit 1
fi
